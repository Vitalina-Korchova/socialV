
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model user{
  id Int @id @default(autoincrement())
  username String
  email String @unique
  password String
  amount_xp Int @default(0)
  level Int @default(1)
  amount_coins Int @default(50)
  created_at DateTime @default(now())


  reset_password user_reset_password[]
  refresh_token used_refresh_token[]
  posts post[]
  liles like[]
  saved_posts saved_post[]
  reposts repost[]
  comments comment[]
  followers following[] @relation("UserFollowers")
  followings following[] @relation("UserFollowings")
  user_shop_items user_shop_item[]
  
  sent_notifications notification[] @relation("NotificationSender")
  received_notifications notification[] @relation("NotificationRecipient")

  first_user_in_chat chat[] @relation("FirstUserChat")
  second_user_in_chat chat[] @relation("SecondUserChat")

  sent_messages message[] @relation("MessageSender")


}

model user_reset_password{
  id Int @id @default(autoincrement())
  code_hash String
  expires_at DateTime
  used Boolean @default(false)

  user_id Int
  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())
}

model used_refresh_token {
  id        Int      @id @default(autoincrement())  
  token_id   String   @unique                        
  user_id    Int                                     
  expires_at DateTime                                
  created_at DateTime @default(now())              

  user      user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}


model post{
  id Int  @id @default(autoincrement())  
  text_content String
  user_id Int
  created_at DateTime @default(now())   

  images post_image[] 
  likes like[]
  saved_post saved_post[]
  reposts repost[]
  comments comment[]
  notifications notification[]

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)  
  
  
}


model image {
  id Int  @id @default(autoincrement())  
  url String
  type_image String @default("user-post")


  post_image post_image[]
  item_images shop_item[]
}

model post_image{
  id Int  @id @default(autoincrement())  
  post_id Int 
  image_id Int

  post post @relation(fields: [post_id], references: [id], onDelete: Cascade)
  image image @relation(fields: [image_id], references: [id], onDelete: Cascade)
}

model like{
   id Int  @id @default(autoincrement())  
   user_id Int 
   post_id Int
   created_at DateTime @default(now())    

   user user @relation(fields: [user_id], references: [id] ,onDelete: Cascade)
   post post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
}

model saved_post{
   id Int  @id @default(autoincrement())  
   post_id Int
   user_id Int
   created_at DateTime @default(now())    

   user user @relation(fields: [user_id], references: [id] ,onDelete: Cascade)
   post post @relation(fields: [post_id], references: [id], onDelete: Cascade)
  @@unique([user_id, post_id])
}

model repost {
   id Int  @id @default(autoincrement())  
   post_id Int
   user_id Int
   created_at DateTime @default(now())    

   user user @relation(fields: [user_id], references: [id] ,onDelete: Cascade)
   post post @relation(fields: [post_id], references: [id], onDelete: Cascade)
  @@unique([user_id, post_id])
}

model comment{
  id Int  @id @default(autoincrement())  
  text String
  user_id Int
  post_id Int
  created_at DateTime @default(now())    

  user user @relation(fields: [user_id], references: [id] ,onDelete: Cascade)
  post post @relation(fields: [post_id], references: [id], onDelete: Cascade)
}

model following{
   id Int  @id @default(autoincrement())  
   follower_id Int  // хто підписується
   following_id Int  // на кого підписуються
   created_at DateTime @default(now())   

   follower user @relation("UserFollowers", fields: [follower_id], references: [id], onDelete: Cascade)
   following user @relation( "UserFollowings", fields: [following_id], references: [id], onDelete: Cascade)

   @@unique([follower_id,following_id])
}

enum item_shop_type {
  AVATAR
  BACKGROUND
  BADGE
  BORDER
}

model shop_item {
  id Int  @id @default(autoincrement())  
  type item_shop_type
  item_image_id Int?
  required_level Int 
  price_coins Int @default(0)
  is_free Boolean @default(false)
  badge_name String? 

  item_image image? @relation(fields: [item_image_id], references: [id], onDelete: Cascade)
  user_shop_items user_shop_item[]
}


model user_shop_item{
  id Int  @id @default(autoincrement())  
  user_id Int
  shop_item_id Int
  is_active Boolean  @default(false)

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shop_item shop_item @relation(fields: [shop_item_id], references: [id], onDelete: Cascade)
  @@unique([user_id, shop_item_id])

}

enum notifications_type {
  LIKE
  REPOST
  COMMENT
  FOLLOW
  LVLUP
}

model notification{
  id Int  @id @default(autoincrement())  
  notification_type notifications_type
  
  sender_id Int
  sender user @relation("NotificationSender", fields: [sender_id], references: [id], onDelete: Cascade)

  recipient_id Int
  recipient user @relation("NotificationRecipient", fields: [recipient_id], references: [id], onDelete: Cascade)

  post_id Int?
  post post? @relation(fields: [post_id], references: [id], onDelete: Cascade)

  is_read Boolean @default(false)
  created_at DateTime @default(now())
  metadata String?
}

model chat{
  id Int  @id @default(autoincrement()) 

  first_user_id Int
  first_user user @relation("FirstUserChat", fields: [first_user_id], references: [id], onDelete: Cascade)

  second_user_id Int
  second_user user @relation("SecondUserChat", fields: [ second_user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  messages message[]

  @@unique([first_user_id, second_user_id])
}

model message{
  id Int  @id @default(autoincrement()) 

  chat_id Int
  chat chat @relation(fields: [chat_id ], references: [id], onDelete: Cascade)

  sender_id    Int     
  sender       user     @relation("MessageSender", fields: [sender_id], references: [id], onDelete: Cascade)

  text_content String
  is_read Boolean @default(false)

  created_at DateTime @default(now())

}

enum action_type_score {
  CREATE_POST
  SET_LIKE
  SET_REPOST
  SET_BOOKMARK
  SET_COMMENT
  RECEIVE_LIKE
  RECEIVE_REPOST
  RECEIVE_COMMENT
  START_FOLLOW
  RECEIVE_FOLLOW
  CREATE_MESSAGE
  RECEIVE_MESSAGE
}

model xp_rules{
  id Int  @id @default(autoincrement()) 
  type action_type_score
  xp_amount Int @default(5)
  coins_amount Int @default(5)
  daily_limit Int 
}

model user_level_rules{
  id Int  @id @default(autoincrement()) 
  level Int @unique
  required_experience Int
  reward_coins Int @default(0)
}
